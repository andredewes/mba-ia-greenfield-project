# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DB_HOST=db
DB_PORT=5432
DB_USERNAME=streamtube
DB_PASSWORD=streamtube
DB_NAME=streamtube

# JWT
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
CONFIRMATION_TOKEN_EXPIRATION_HOURS=1
PASSWORD_RESET_TOKEN_EXPIRATION_HOURS=1

# Mail (Mailpit for local development)
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM="StreamTube <noreply@streamtube.com>"

# Object Storage (MinIO / S3-compatible)
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=streamtube-videos
S3_FORCE_PATH_STYLE=true
UPLOAD_PART_SIZE_BYTES=104857600
UPLOAD_PRESIGN_EXPIRY_SECONDS=21600
DOWNLOAD_PRESIGN_EXPIRY_SECONDS=3600

# Queue (Redis / BullMQ)
REDIS_HOST=redis
REDIS_PORT=6379
VIDEO_PROCESSING_ATTEMPTS=3
VIDEO_PROCESSING_BACKOFF_MS=5000
